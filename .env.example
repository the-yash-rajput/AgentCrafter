# Database
DATABASE_URL=postgresql://langgraph:langgraph_secret@localhost:5733/lbdnew
POSTGRES_HOST_PORT=5733

# LLM API Keys (referenced by name in node config, not stored in DB)
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-10-21
ANTHROPIC_API_KEY=sk-ant-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_HOST=
LANGFUSE_PROMPT_MANAGEMENT=true
PROFILE_ENV=local
ENV_NAMESPACE=sanity

# App
SECRET_KEY=change-me-in-production
BACKEND_LOG_LEVEL=debug
BACKEND_RELOAD=true
BACKEND_DEBUGPY=false
BACKEND_DEBUGPY_HOST=0.0.0.0
BACKEND_DEBUGPY_PORT=5678
BACKEND_DEBUGPY_WAIT_FOR_CLIENT=false
BACKEND_DEBUGPY_SUBPROCESS=false
