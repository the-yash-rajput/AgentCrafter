{
  "agent": {
    "name": "All Cases Import Example",
    "description": "Import sample covering all node and edge configuration cases.",
    "input_schema": {
      "input": "string",
      "priority": "string",
      "score": "number",
      "next_step": "string"
    },
    "output_schema": {
      "result": "string",
      "final_status": "string",
      "final_route": "string"
    },
    "state_schema": {
      "input": "string",
      "prepared_prompt": "string",
      "priority": "string",
      "score": "number",
      "next_step": "string",
      "openai_response": "string",
      "anthropic_response": "string",
      "api_result": "object",
      "result": "string",
      "final_status": "string",
      "final_route": "string"
    },
    "entry_node": "seed_state",
    "exit_node": "end_node"
  },
  "nodes": [
    {
      "name": "seed_state",
      "type": "functional",
      "config": {
        "function_type": "python_inline",
        "python_inline": {
          "code": "def run(state):\n    state = dict(state)\n    state.setdefault('input', 'Hello from import sample')\n    state.setdefault('priority', 'low')\n    state.setdefault('score', 0.3)\n    state.setdefault('next_step', 'finish')\n    state['prepared_prompt'] = f\"Summarize: {state.get('input', '')}\"\n    return state"
        }
      },
      "position_x": 80,
      "position_y": 80
    },
    {
      "name": "transform_data",
      "type": "functional",
      "config": {
        "function_type": "data_transform",
        "data_transform": {
          "operations": [
            {
              "type": "extract",
              "config": {
                "key": "input",
                "new_key": "result"
              }
            },
            {
              "type": "merge",
              "config": {
                "data": {
                  "final_status": "in_progress"
                }
              }
            }
          ]
        }
      },
      "position_x": 320,
      "position_y": 80
    },
    {
      "name": "priority_router",
      "type": "functional",
      "config": {
        "function_type": "python_inline",
        "python_inline": {
          "code": "def run(state):\n    return state"
        }
      },
      "position_x": 560,
      "position_y": 80
    },
    {
      "name": "high_enrichment_llm_openai",
      "type": "llm_call",
      "config": {
        "provider": "azure_openai",
        "model": "ai-agent-4o",
        "api_key_env_var": "AZURE_OPENAI_API_KEY",
        "system_prompt": "You are a concise assistant.",
        "user_prompt_template": "{{prepared_prompt}}",
        "temperature": 0.2,
        "max_tokens": 120,
        "output_key": "openai_response",
        "parse_json_response": false
      },
      "position_x": 820,
      "position_y": 0
    },
    {
      "name": "low_enrichment_llm_anthropic",
      "type": "llm_call",
      "config": {
        "provider": "anthropic",
        "model": "claude-3-haiku-20240307",
        "api_key_env_var": "ANTHROPIC_API_KEY",
        "system_prompt": "You are a concise assistant.",
        "user_prompt_template": "{{prepared_prompt}}",
        "temperature": 0.2,
        "max_tokens": 120,
        "output_key": "anthropic_response",
        "parse_json_response": false
      },
      "position_x": 820,
      "position_y": 160
    },
    {
      "name": "score_router",
      "type": "functional",
      "config": {
        "function_type": "python_inline",
        "python_inline": {
          "code": "def run(state):\n    state = dict(state)\n    state['score'] = float(state.get('score', 0))\n    return state"
        }
      },
      "position_x": 1080,
      "position_y": 80
    },
    {
      "name": "score_true_path",
      "type": "functional",
      "config": {
        "function_type": "python_inline",
        "python_inline": {
          "code": "def run(state):\n    state = dict(state)\n    state['final_route'] = 'score_true_path'\n    if state.get('next_step') not in ['use_api', 'finish']:\n        state['next_step'] = 'use_api'\n    return state"
        }
      },
      "position_x": 1340,
      "position_y": 20
    },
    {
      "name": "score_false_path",
      "type": "functional",
      "config": {
        "function_type": "python_inline",
        "python_inline": {
          "code": "def run(state):\n    state = dict(state)\n    state['final_route'] = 'score_false_path'\n    if state.get('next_step') not in ['use_api', 'finish']:\n        state['next_step'] = 'finish'\n    return state"
        }
      },
      "position_x": 1340,
      "position_y": 160
    },
    {
      "name": "next_step_router",
      "type": "functional",
      "config": {
        "function_type": "python_inline",
        "python_inline": {
          "code": "def run(state):\n    return state"
        }
      },
      "position_x": 1600,
      "position_y": 80
    },
    {
      "name": "api_call_case",
      "type": "functional",
      "config": {
        "function_type": "api_call",
        "api_call": {
          "url": "https://httpbin.org/post",
          "method": "POST",
          "headers": {
            "Content-Type": "application/json"
          },
          "body_template": "{\"text\": \"{{prepared_prompt}}\", \"score\": {{score}}}",
          "output_key": "api_result"
        }
      },
      "position_x": 1860,
      "position_y": 20
    },
    {
      "name": "final_transform",
      "type": "functional",
      "config": {
        "function_type": "data_transform",
        "data_transform": {
          "operations": [
            {
              "type": "merge",
              "config": {
                "data": {
                  "final_status": "complete"
                }
              }
            }
          ]
        }
      },
      "position_x": 1860,
      "position_y": 160
    },
    {
      "name": "end_node",
      "type": "functional",
      "config": {
        "function_type": "python_inline",
        "python_inline": {
          "code": "def run(state):\n    state = dict(state)\n    state['result'] = state.get('result') or state.get('input', '')\n    return state"
        }
      },
      "position_x": 2120,
      "position_y": 160
    }
  ],
