{
  "agent": {
    "name": "Basic Demo Workflow",
    "description": "Small demo graph with one mock LLM node, functional nodes, direct edges, and conditional edges. Runs without external API keys and clearly shows both branches.",
    "input_schema": {
      "customer_name": {
        "type": "string",
        "description": "Name shown in the demo response"
      },
      "request_text": {
        "type": "string",
        "description": "Short request used by the demo flow"
      },
      "requires_review": {
        "type": "boolean",
        "description": "Set true to send the flow down the review branch"
      }
    },
    "output_schema": {
      "ack_message": {
        "type": "string"
      },
      "route": {
        "type": "string"
      },
      "result": {
        "type": "string"
      },
      "final_message": {
        "type": "string"
      },
      "final_summary": {
        "type": "string"
      }
    },
    "state_schema": {
      "customer_name": {
        "type": "string",
        "default": "Demo User"
      },
      "request_text": {
        "type": "string",
        "default": "Need a quick quote demo"
      },
      "requires_review": {
        "type": "boolean",
        "default": false
      },
      "route": {
        "type": "string",
        "default": "approved"
      },
      "result": {
        "type": "string",
        "default": ""
      }
    },
    "entry_node": "prepare_request",
    "exit_node": "final_output"
  },
  "nodes": [
    {
      "id": 2001,
      "name": "prepare_request",
      "type": "functional",
      "config": {
        "function_type": "python_inline",
        "python_inline": {
          "code": "def run(state):\n    out = dict(state or {})\n    out.setdefault('customer_name', 'Demo User')\n    out.setdefault('request_text', 'Need a quick quote demo')\n    out.setdefault('requires_review', False)\n    out['prepared'] = True\n    return out\n"
        }
      },
      "position_x": 80,
      "position_y": 220
    },
    {
      "id": 2002,
      "name": "llm_acknowledgement",
      "type": "llm_call",
      "config": {
        "provider": "demo_mock",
        "model": "demo-response",
        "system_prompt": "You are a short demo assistant.",
        "user_prompt_template": "Acknowledge {{customer_name}} and the request: {{request_text}}",
        "temperature": 0,
        "max_tokens": 50,
        "output_key": "ack_message",
        "parse_json_response": false
      },
      "position_x": 360,
      "position_y": 220
    },
    {
      "id": 2003,
      "name": "route_request",
      "type": "functional",
      "config": {
        "function_type": "python_inline",
        "python_inline": {
          "code": "def run(state):\n    out = dict(state or {})\n    out['route'] = 'needs_review' if out.get('requires_review') else 'approved'\n    return out\n"
        }
      },
      "position_x": 640,
      "position_y": 220
    },
    {
      "id": 2004,
      "name": "approved_path",
      "type": "functional",
      "config": {
        "function_type": "python_inline",
        "python_inline": {
          "code": "def run(state):\n    out = dict(state or {})\n    out['result'] = 'approved'\n    out['final_message'] = f\"Approved automatically for {out.get('customer_name')}. LLM note: {out.get('ack_message')}\"\n    return out\n"
        }
      },
      "position_x": 920,
      "position_y": 120
    },
    {
      "id": 2005,
      "name": "review_path",
      "type": "functional",
      "config": {
        "function_type": "python_inline",
        "python_inline": {
          "code": "def run(state):\n    out = dict(state or {})\n    out['result'] = 'needs_review'\n    out['final_message'] = f\"Sent for manual review for {out.get('customer_name')}. LLM note: {out.get('ack_message')}\"\n    return out\n"
        }
      },
      "position_x": 920,
      "position_y": 320
    },
    {
      "id": 2006,
      "name": "final_output",
      "type": "functional",
      "config": {
        "function_type": "python_inline",
        "python_inline": {
          "code": "def run(state):\n    out = dict(state or {})\n    out['final_summary'] = f\"route={out.get('route')} | result={out.get('result')} | message={out.get('final_message')}\"\n    return out\n"
        }
      },
      "position_x": 1220,
      "position_y": 220
    }
  ],
  "edges": [
    {
      "source_node_id": 2001,
      "target_node_id": 2002,
      "edge_type": "direct",
      "condition_config": {},
      "label": ""
    },
    {
      "source_node_id": 2002,
      "target_node_id": 2003,
      "edge_type": "direct",
      "condition_config": {},
      "label": ""
    },
    {
      "source_node_id": 2003,
      "target_node_id": 2004,
      "edge_type": "conditional",
      "condition_config": {
        "condition_type": "state_key_equals",
        "state_key_equals": {
          "key": "route",
          "value": "approved"
        }
      },
      "label": "approved"
    },
    {
      "source_node_id": 2003,
      "target_node_id": 2005,
      "edge_type": "conditional",
      "condition_config": {
        "condition_type": "state_key_equals",
        "state_key_equals": {
          "key": "route",
          "value": "needs_review"
        }
      },
      "label": "needs_review"
    },
    {
      "source_node_id": 2004,
      "target_node_id": 2006,
      "edge_type": "direct",
      "condition_config": {},
      "label": ""
    },
    {
      "source_node_id": 2005,
      "target_node_id": 2006,
      "edge_type": "direct",
      "condition_config": {},
      "label": ""
    }
  ]
}
