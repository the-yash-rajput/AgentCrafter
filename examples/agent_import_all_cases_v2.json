      "config": {
        "function_type": "python_inline",
        "python_inline": {
          "code": "def run(state):\n    out = dict(state or {})\n    out.setdefault('messages', [])\n    out.setdefault('payload', {})\n    out['started'] = True\n    return out"
        }
      },
      "position_x": 80,
      "position_y": 230,
      "id": 1001
    },
